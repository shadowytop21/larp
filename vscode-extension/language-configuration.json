{
  "comments": {
    "lineComment": "note:"
  },
  "brackets": [["(", ")"], ["[", "]"]],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"" }
  ],
  "onEnterRules": [
    {
      "beforeText": ".*:$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*end$",
      "action": { "indent": "outdent" }
    }
  ],
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "indentationRules": {
    "increaseIndentPattern": ".*:$",
    "decreaseIndentPattern": "^\\s*(end|otherwise|otherwise if|if something goes wrong)\\b"
  }
}
